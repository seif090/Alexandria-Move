# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:5000

# Map Configuration (MapLibre + OpenFreeMap)
EXPO_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Routing Engine (OSRM)
EXPO_PUBLIC_OSRM_URL=https://router.project-osrm.org

# Geocoding (Nominatim)
EXPO_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Google Sign-In (only used for auth, no map dependency)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
